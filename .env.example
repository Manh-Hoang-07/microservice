# ─── RUNTIME ─────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_TIMEZONE=Asia/Ho_Chi_Minh
# Overrides the default 'api' prefix for all services
GLOBAL_PREFIX=api
# CORS_ENABLED: set to false to disable CORS entirely
CORS_ENABLED=true
# Comma-separated allowed CORS origins (* = all)
CORS_ORIGINS=http://localhost:3000

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Each service uses the same var name but should point to its own DB
DATABASE_URL="postgresql://postgres:123456@localhost:5432/comic"
# DIRECT_URL bypasses the connection pooler for Prisma migrations
DIRECT_URL="postgresql://postgres:123456@localhost:5432/comic"

# ─── AUTH & SECURITY ──────────────────────────────────────────────────────────
# auth-service: RSA key pair for JWT signing (PEM format)
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=auth-service
JWT_AUDIENCE=comic-platform

# Non-auth services verify JWTs via this JWKS endpoint (exposed by auth-service)
AUTH_JWKS_URL=http://localhost:3002/.well-known/jwks.json
# Shared secret for internal service-to-service API calls
INTERNAL_API_SECRET=your-internal-api-secret-here

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
BFF_REDIS_URL=redis://localhost:6383

# ─── KAFKA ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9093
# EVENT_DRIVER: 'local' (direct DB write) | 'kafka' (Outbox pattern)
EVENT_DRIVER=local
# notification-service consumer group ID
KAFKA_GROUP_ID=notification-service

# ─── GOOGLE OAUTH (auth-service) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/api/google/callback
GOOGLE_FRONTEND_URL=http://localhost:3000

# ─── MAIL (auth-service + notification-service) ───────────────────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# ─── STORAGE SERVICE ──────────────────────────────────────────────────────────
# STORAGE_TYPE: 'local' | 's3' | 'cloudinary'
STORAGE_TYPE=local
STORAGE_MAX_FILE_SIZE=10485760

# S3 / Supabase Storage
STORAGE_S3_BUCKET=uploads
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_ENDPOINT=
STORAGE_S3_BASE_URL=
STORAGE_S3_FORCE_PATH_STYLE=true

# Cloudinary (alternative to S3)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── BFF SERVICE ──────────────────────────────────────────────────────────────
COMIC_SERVICE_URL=http://localhost:3001/api
MAIN_SERVICE_URL=http://localhost:8000/api
SERVICE_TIMEOUT_MS=5000
