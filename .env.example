# ─── RUNTIME ─────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_TIMEZONE=Asia/Ho_Chi_Minh
# Overrides the default 'api' prefix for all services
GLOBAL_PREFIX=api
# Per-service port (each service overrides via its own env when running together)
# auth=3002 comic=3001 notification=3004 config=3005 web-api=3006 post=3007
# storage=3003 iam=3008 marketing=3009 introduction=3010
PORT=3000
# Per-service tracing identifier (set differently per service in production)
SERVICE_NAME=comic-platform
# Public base URL of the auth-service — used to build OAuth callback URLs
APP_URL=http://localhost:3002
# CORS_ENABLED: set to false to disable CORS entirely
CORS_ENABLED=true
# Comma-separated allowed CORS origins (* = wildcard, REJECTED in production)
CORS_ORIGINS=http://localhost:3000

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Each service uses the same var name but should point to its own DB
DATABASE_URL="postgresql://postgres:123456@localhost:5432/comic"
# DIRECT_URL bypasses the connection pooler for Prisma migrations
DIRECT_URL="postgresql://postgres:123456@localhost:5432/comic"

# ─── AUTH & SECURITY ──────────────────────────────────────────────────────────
# auth-service: RSA key pair for JWT signing (PEM format) — REQUIRED in prod.
# Generate locally with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=auth-service
JWT_AUDIENCE=comic-platform

# Non-auth services verify JWTs via this JWKS endpoint (exposed by auth-service)
# REQUIRED in production for every service.
AUTH_JWKS_URL=http://localhost:3002/.well-known/jwks.json
# IAM service URL for cross-service RBAC checks. RbacGuard fails closed in
# production if this is unset.
IAM_INTERNAL_URL=http://localhost:3008/api
# notification-service fetches SMTP config from config-service via this URL.
CONFIG_INTERNAL_URL=http://localhost:3005/api
# Shared secret for internal service-to-service API calls.
# REQUIRED in production, MUST be ≥ 16 chars and unguessable.
# DO NOT ship this default to prod — generate with `openssl rand -base64 32`.
INTERNAL_API_SECRET=

# auth-service brute-force / lockout tuning
SECURITY_ATTEMPT_MAX=5
SECURITY_ATTEMPT_WINDOW_SECONDS=900
SECURITY_ATTEMPT_LOCKOUT_SECONDS=1800
OTP_TTL_SECONDS=300
BCRYPT_ROUNDS=12

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
GATEWAY_REDIS_URL=redis://localhost:6383

# ─── KAFKA ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9093
# EVENT_DRIVER: 'local' (direct DB write) | 'kafka' (Outbox pattern)
EVENT_DRIVER=local
# notification-service consumer group ID
KAFKA_GROUP_ID=notification-service

# ─── GOOGLE OAUTH (auth-service) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/api/auth/google/callback
# Frontend redirect target after OAuth — must be https in production.
GOOGLE_FRONTEND_URL=http://localhost:3000
# HMAC key for OAuth `state` CSRF cookie. REQUIRED in production when
# Google OAuth is enabled. Generate with `openssl rand -base64 32`.
GOOGLE_OAUTH_STATE_SECRET=

# ─── MAIL (config-service stores SMTP creds at runtime) ───────────────────────
# config-service writes SMTP config to its DB; notification-service fetches
# it via the internal endpoint above. Bootstrap creds may also be set here
# for the very first deploy and migrated into config-service afterwards.
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# ─── STORAGE SERVICE ──────────────────────────────────────────────────────────
# STORAGE_TYPE: 'local' | 's3' | 'cloudinary'
STORAGE_TYPE=local
STORAGE_MAX_FILE_SIZE=10485760
STORAGE_LOCAL_PATH=./storage/uploads
STORAGE_LOCAL_BASE_URL=/api/upload

# Comma-separated MIME types allowed for upload (empty = allow all)
STORAGE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif

# S3 / MinIO — REQUIRED when STORAGE_TYPE=s3
STORAGE_S3_BUCKET=uploads
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_ENDPOINT=
STORAGE_S3_BASE_URL=
STORAGE_S3_FORCE_PATH_STYLE=true

# Cloudinary — REQUIRED when STORAGE_TYPE=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── WEB API SERVICE ──────────────────────────────────────────────────────────
COMIC_SERVICE_URL=http://localhost:3001/api
POST_SERVICE_URL=http://localhost:3007/api
SERVICE_TIMEOUT_MS=5000

# ─── IAM SERVICE ──────────────────────────────────────────────────────────────
RBAC_CACHE_TTL=86400
RBAC_CACHE_VERSION_TTL_MS=2000

# ─── OBSERVABILITY ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
