{
  "name": "comic-platform",
  "version": "2.0.0",
  "description": "Comic Platform — Microservices Architecture",
  "private": true,
  "license": "MIT",
  "scripts": {
    "install:auth": "npm --prefix apps/auth-service install",
    "install:storage": "npm --prefix apps/storage-service install",
    "install:config": "npm --prefix apps/config-service install",
    "install:bff": "npm --prefix apps/bff-service install",
    "install:comic": "npm --prefix apps/comic-service install",
    "install:notif": "npm --prefix apps/notification-service install",
    "install:post": "npm --prefix apps/post-service install",
    "install:intro": "npm --prefix apps/introduction-service install",
    "install:marketing": "npm --prefix apps/marketing-service install",
    "install:all": "npm run install:auth && npm run install:storage && npm run install:config && npm run install:bff && npm run install:comic && npm run install:notif && npm run install:post && npm run install:intro && npm run install:marketing",
    "start:auth": "npm --prefix apps/auth-service run start",
    "start:storage": "npm --prefix apps/storage-service run start",
    "start:config": "npm --prefix apps/config-service run start",
    "start:bff": "npm --prefix apps/bff-service run start",
    "start:comic": "npm --prefix apps/comic-service run start",
    "start:notif": "npm --prefix apps/notification-service run start",
    "start:post": "npm --prefix apps/post-service run start",
    "start:intro": "npm --prefix apps/introduction-service run start",
    "start:marketing": "npm --prefix apps/marketing-service run start",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build"
  }
}
