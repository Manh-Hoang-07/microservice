{
  "name": "comic-platform",
  "version": "2.0.0",
  "description": "Comic Platform — Microservices Architecture",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "shared/*",
    "apps/*"
  ],
  "scripts": {
    "postinstall": "npm run build:shared --if-present",
    "prestart": "npm run build:shared",
    "build:shared": "npm -w shared/shared-types run build && npm -w shared/circuit-breaker run build && npm -w shared/config run build && npm -w shared/redis run build && npm -w shared/kafka-client run build && npm -w shared/tracing run build && npm -w shared/common run build && npm -w shared/bootstrap run build",
    "build:auth": "npm -w apps/auth-service run build",
    "build:comic": "npm -w apps/comic-service run build",
    "build:config": "npm -w apps/config-service run build",
    "build:web-api": "npm -w apps/web-api-service run build",
    "build:iam": "npm -w apps/iam-service run build",
    "build:introduction": "npm -w apps/introduction-service run build",
    "build:marketing": "npm -w apps/marketing-service run build",
    "build:notification": "npm -w apps/notification-service run build",
    "build:post": "npm -w apps/post-service run build",
    "build:storage": "npm -w apps/storage-service run build",
    "build:apps": "npm run build:auth && npm run build:comic && npm run build:config && npm run build:web-api && npm run build:iam && npm run build:introduction && npm run build:marketing && npm run build:notification && npm run build:post && npm run build:storage",
    "build": "npm run build:shared && npm run build:apps",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "start:auth": "npm -w apps/auth-service run start",
    "start:comic": "npm -w apps/comic-service run start",
    "start:config": "npm -w apps/config-service run start",
    "start:web-api": "npm -w apps/web-api-service run start",
    "start:iam": "npm -w apps/iam-service run start",
    "start:introduction": "npm -w apps/introduction-service run start",
    "start:marketing": "npm -w apps/marketing-service run start",
    "start:notification": "npm -w apps/notification-service run start",
    "start:post": "npm -w apps/post-service run start",
    "start:storage": "npm -w apps/storage-service run start",
    "start": "concurrently --prefix-colors blue,magenta,cyan,green,yellow,red,white,gray,blueBright,magentaBright -n auth,comic,config,web-api,introduction,marketing,notification,post,storage,iam \"npm:start:auth\" \"npm:start:comic\" \"npm:start:config\" \"npm:start:web-api\" \"npm:start:introduction\" \"npm:start:marketing\" \"npm:start:notification\" \"npm:start:post\" \"npm:start:storage\" \"npm:start:iam\"",
    "prisma:generate:auth": "npm -w apps/auth-service run prisma:generate",
    "prisma:generate:comic": "npm -w apps/comic-service run prisma:generate",
    "prisma:generate:config": "npm -w apps/config-service run prisma:generate",
    "prisma:generate:iam": "npm -w apps/iam-service run prisma:generate",
    "prisma:generate:introduction": "npm -w apps/introduction-service run prisma:generate",
    "prisma:generate:marketing": "npm -w apps/marketing-service run prisma:generate",
    "prisma:generate:notification": "npm -w apps/notification-service run prisma:generate",
    "prisma:generate:post": "npm -w apps/post-service run prisma:generate",
    "prisma:generate": "npm run prisma:generate:auth && npm run prisma:generate:comic && npm run prisma:generate:config && npm run prisma:generate:iam && npm run prisma:generate:introduction && npm run prisma:generate:marketing && npm run prisma:generate:notification && npm run prisma:generate:post",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:infra": "docker compose up -d kafka kafka-ui auth-db comic-db notification-db config-db post-db introduction-db marketing-db iam-db auth-redis comic-redis notification-redis post-redis web-api-redis iam-redis jaeger",
    "docker:infra:down": "docker compose stop kafka kafka-ui auth-db comic-db notification-db config-db post-db introduction-db marketing-db iam-db auth-redis comic-redis notification-redis post-redis web-api-redis iam-redis jaeger",
    "nginx:up": "docker compose --profile dev up -d nginx-dev",
    "nginx:down": "docker compose --profile dev rm -sf nginx-dev",
    "production:check": "./scripts/production-ready-check.sh",
    "production:ready": "./scripts/make-production-ready.sh"
  },
  "devDependencies": {
    "@swc/core": "^1.15.33",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9"
  }
}
