{
  "name": "nestjs-backend",
  "version": "1.0.0",
  "description": "NestJS backend converted from Laravel",
  "author": "",
  "private": true,
  "license": "MIT",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build && tsc-alias",
    "postinstall": "prisma generate",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "install:storage": "npm --prefix storage-service install",
    "install:bff": "npm --prefix bff-service install",
    "install:auth": "npm --prefix auth-service install",
    "install:config": "npm --prefix config-service install",
    "install:comic": "npm --prefix comic-service install",
    "install:notif": "npm --prefix notification-service install",
    "install:services": "npm --prefix storage-service install && npm --prefix bff-service install && npm --prefix auth-service install && npm --prefix config-service install && npm --prefix comic-service install && npm --prefix notification-service install",
    "start:storage": "npm --prefix storage-service run start",
    "start:bff": "npm --prefix bff-service run start",
    "start:auth": "npm --prefix auth-service run start",
    "start:config": "npm --prefix config-service run start",
    "start:comic": "npm --prefix comic-service run start",
    "start:notif": "npm --prefix notification-service run start",
    "k6:smoke": "k6 run ./loadtest/k6/smoke.js",
    "k6:browse": "k6 run ./loadtest/k6/public-browse.js",
    "k6:user": "k6 run ./loadtest/k6/user-journey.js",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:migrate:reset": "prisma migrate reset",
    "prisma:db:push": "prisma db push",
    "migration:run": "prisma migrate deploy",
    "migration:create": "prisma migrate dev --create-only --name",
    "migration:generate": "prisma migrate dev --name",
    "migration:status": "prisma migrate status",
    "lint": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "node --max-old-space-size=4096 node_modules/jest/bin/jest.js --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "db:create": "ts-node -r tsconfig-paths/register src/core/database/cli/create-database.ts",
    "db:drop": "ts-node -r tsconfig-paths/register src/core/database/cli/drop-database.ts",
    "seed": "ts-node -r tsconfig-paths/register src/core/database/cli/seed.ts",
    "seed:refresh": "ts-node -r tsconfig-paths/register src/core/database/cli/seed.ts --refresh",
    "seed:prod": "node dist/core/database/cli/seed.js",
    "seed:refresh:prod": "node dist/core/database/cli/seed.js --refresh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@logtail/node": "^0.5.8",
    "@nestjs-modules/mailer": "^2.0.0",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-mariadb": "^7.6.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/multer": "^2.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "bcryptjs": "^3.0.2",
    "bull": "^4.16.5",
    "cache-manager": "^7.2.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.8.2",
    "joi": "^18.1.2",
    "jose": "^6.2.3",
    "kafkajs": "^2.2.4",
    "lru-cache": "^11.3.5",
    "mariadb": "^3.5.2",
    "module-alias": "^2.2.3",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "rate-limiter-flexible": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.19",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.19",
    "@types/bull": "^3.15.9",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/hpp": "^0.2.7",
    "@types/jest": "^30.0.0",
    "@types/module-alias": "^2.0.4",
    "@types/node": "^20.10.6",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "baseline-browser-mapping": "^2.10.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "prettier": "^3.1.1",
    "prisma": "^7.6.0",
    "puppeteer": "^24.42.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|s)s"
    ],
    "coverageDirectory": "coverage",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/test/jest-setup.js"
    ]
  }
}
