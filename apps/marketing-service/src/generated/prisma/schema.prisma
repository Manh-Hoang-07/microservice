generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ContactStatus {
  Pending
  Read
  Replied
  Closed
}

enum BannerLinkTarget {
  SELF  @map("_self")
  BLANK @map("_blank")
}

model BannerLocation {
  id          BigInt   @id @default(autoincrement())
  code        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  status      String   @default("active") @db.VarChar(30)
  created_at  DateTime @default(now()) @db.Timestamp(0)
  updated_at  DateTime @updatedAt @db.Timestamp(0)

  banners Banner[]

  @@index([code], map: "banner_locations_idx_code")
  @@index([status], map: "banner_locations_idx_status")
  @@map("banner_locations")
}

model Banner {
  id           BigInt           @id @default(autoincrement())
  title        String           @db.VarChar(255)
  subtitle     String?          @db.VarChar(500)
  image        String?          @db.VarChar(500)
  mobile_image String?          @db.VarChar(500)
  link         String?          @db.VarChar(500)
  link_target  BannerLinkTarget @default(SELF)
  description  String?          @db.Text
  button_text  String?          @db.VarChar(100)
  button_color String?          @db.VarChar(50)
  text_color   String?          @db.VarChar(50)
  location_id  BigInt
  sort_order   Int              @default(0)
  status       String           @default("active") @db.VarChar(30)
  start_date   DateTime?        @db.Timestamp(0)
  end_date     DateTime?        @db.Timestamp(0)
  created_at   DateTime         @default(now()) @db.Timestamp(0)
  updated_at   DateTime         @updatedAt @db.Timestamp(0)

  location BannerLocation @relation(fields: [location_id], references: [id], onDelete: Cascade)

  @@index([location_id], map: "banners_idx_location_id")
  @@index([status], map: "banners_idx_status")
  @@index([sort_order], map: "banners_idx_sort_order")
  @@index([start_date], map: "banners_idx_start_date")
  @@index([end_date], map: "banners_idx_end_date")
  @@map("banners")
}

model Contact {
  id         BigInt        @id @default(autoincrement())
  name       String        @db.VarChar(255)
  email      String        @db.VarChar(255)
  phone      String?       @db.VarChar(50)
  message    String        @db.Text
  status     ContactStatus @default(Pending)
  reply      String?       @db.Text
  replied_at DateTime?     @db.Timestamp(0)
  replied_by BigInt?
  created_at DateTime      @default(now()) @db.Timestamp(0)
  updated_at DateTime      @updatedAt @db.Timestamp(0)

  @@index([status], map: "contacts_idx_status")
  @@index([email], map: "contacts_idx_email")
  @@index([created_at], map: "contacts_idx_created_at")
  @@map("contacts")
}

model MarketingOutbox {
  id         BigInt   @id @default(autoincrement())
  event_type String   @db.VarChar(100)
  payload    Json
  published  Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(0)

  @@index([published, created_at], map: "marketing_outbox_idx_published")
  @@map("marketing_outbox")
}
