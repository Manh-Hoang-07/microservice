# -- App -----------------------------------------------------------------------
PORT=3009
NODE_ENV=development
GLOBAL_PREFIX=api
CORS_ORIGINS=*

# -- PostgreSQL ----------------------------------------------------------------
DATABASE_URL=postgresql://postgres:secret@localhost:5440/marketing_db

# -- JWT Guard -----------------------------------------------------------------
AUTH_JWKS_URL=http://localhost:3002/.well-known/jwks.json

# -- Kafka ---------------------------------------------------------------------
KAFKA_BROKERS=localhost:9093
EVENT_DRIVER=local

# -- Observability -------------------------------------------------------------
# Leave blank to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
