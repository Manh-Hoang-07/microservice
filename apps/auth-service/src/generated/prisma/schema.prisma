generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// User - Profile
// ============================================

model User {
  id                BigInt    @id @default(autoincrement())
  username          String?   @unique @db.VarChar(50)
  email             String?   @unique @db.VarChar(255)
  phone             String?   @unique @db.VarChar(20)
  password          String?   @db.VarChar(255)
  name              String?   @db.VarChar(255)
  image             String?   @db.VarChar(255)
  googleId          String?   @unique @db.VarChar(255)
  status            String    @default("active") @db.VarChar(30)
  email_verified_at DateTime? @db.Timestamp(0)
  phone_verified_at DateTime? @db.Timestamp(0)
  last_login_at     DateTime? @db.Timestamp(0)
  remember_token    String?   @db.VarChar(100)
  created_user_id   BigInt?
  updated_user_id   BigInt?
  created_at        DateTime  @default(now()) @db.Timestamp(0)
  updated_at        DateTime  @updatedAt @db.Timestamp(0)

  profile Profile?

  @@index([status], map: "users_idx_status")
  @@index([created_at], map: "users_idx_created_at")
  @@index([status, created_at], map: "users_idx_status_created")
  @@map("users")
}

model Profile {
  id              BigInt    @id @default(autoincrement())
  user_id         BigInt    @unique
  birthday        DateTime? @db.Date
  gender          String?   @db.VarChar(20)
  address         String?   @db.Text
  country_id      BigInt?
  province_id     BigInt?
  ward_id         BigInt?
  about           String?   @db.Text
  created_user_id BigInt?
  updated_user_id BigInt?
  created_at      DateTime  @default(now()) @db.Timestamp(0)
  updated_at      DateTime  @updatedAt @db.Timestamp(0)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([province_id], map: "profiles_idx_province_id")
  @@index([country_id], map: "profiles_idx_country_id")
  @@index([user_id], map: "profiles_idx_user_id")
  @@map("profiles")
}

// ============================================
// Outbox Pattern — Kafka at-least-once delivery
// ============================================

model AuthOutbox {
  id         BigInt   @id @default(autoincrement())
  event_type String   @db.VarChar(100)
  payload    Json
  published  Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz()

  @@index([published, created_at])
  @@map("auth_outbox")
}
