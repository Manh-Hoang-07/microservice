# =============================================================================
# Auth Service — Example / Reference
# Priority: .env.local > .env.production > .env
# Copy relevant vars to .env.local (gitignored) and fill in real values.
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
SERVICE_NAME=Auth Service
PORT=3001
NODE_ENV=development
GLOBAL_PREFIX=api/auth
APP_URL=http://localhost:3001
APP_TIMEZONE=Asia/Ho_Chi_Minh
CORS_ORIGINS=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:secret@localhost:5432/auth_db?connection_limit=20&pool_timeout=60

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Leave blank in dev → ephemeral key pair generated on startup
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=auth-service
JWT_AUDIENCE=comic-platform

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Leave blank to disable Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
GOOGLE_FRONTEND_URL=http://localhost:3000
GOOGLE_OAUTH_STATE_SECRET=

# ── Security ──────────────────────────────────────────────────────────────────
SECURITY_ATTEMPT_MAX=5
SECURITY_ATTEMPT_WINDOW_SECONDS=900
SECURITY_ATTEMPT_LOCKOUT_SECONDS=1800
OTP_TTL_SECONDS=300
BCRYPT_ROUNDS=12

# ── IAM (RBAC) ───────────────────────────────────────────────────────────────
# dev: http://localhost/api/iam  |  prod: https://<iam-service>.up.railway.app/api/iam
IAM_INTERNAL_URL=http://localhost/api/iam

# ── Internal ──────────────────────────────────────────────────────────────────
INTERNAL_API_SECRET=change-me-in-production-min-16-chars

# ── Messaging ─────────────────────────────────────────────────────────────────
# local: no broker (default for dev/serverless)
# redis: Redis Streams
# rabbitmq: RabbitMQ cluster
# kafka: Kafka cluster (Aiven, Confluent, ...)
EVENT_DRIVER=local

# Redis Streams (dùng khi EVENT_DRIVER=redis)
REDIS_EVENT_URL=redis://localhost:6380
REDIS_STREAM_MAX_LEN=10000

# RabbitMQ (dùng khi EVENT_DRIVER=rabbitmq)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Kafka (dùng khi EVENT_DRIVER=kafka)
KAFKA_BROKERS=localhost:9092
KAFKA_LINGER_MS=100
KAFKA_BATCH_SIZE=32768
KAFKA_COMPRESSION=snappy
KAFKA_GROUP_ID=auth-service
KAFKA_REPLICATION_FACTOR=3
# SSL for Aiven Kafka — leave empty for local plaintext
KAFKA_CA_CERTIFICATE=
KAFKA_ACCESS_CERTIFICATE=
KAFKA_ACCESS_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
