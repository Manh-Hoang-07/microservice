# =============================================================================
# Auth Service
# =============================================================================

# -- App -----------------------------------------------------------------------
SERVICE_NAME=Auth Service
PORT=3002
APP_URL=http://localhost:3002
APP_TIMEZONE=Asia/Ho_Chi_Minh
NODE_ENV=development
GLOBAL_PREFIX=api
CORS_ORIGINS=*

# -- PostgreSQL ----------------------------------------------------------------
DATABASE_URL=postgresql://postgres:secret@localhost:5433/auth_db

# -- Redis ---------------------------------------------------------------------
REDIS_URL=redis://localhost:6380

# -- JWT (RS256, signer) -------------------------------------------------------
# Leave blank in dev → ephemeral key pair generated on startup
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=auth-service
JWT_AUDIENCE=comic-platform

# -- Google OAuth --------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3002/api/auth/google/callback
GOOGLE_FRONTEND_URL=http://localhost:3000

# -- Security ------------------------------------------------------------------
SECURITY_ATTEMPT_MAX=5
SECURITY_ATTEMPT_WINDOW_SECONDS=900
SECURITY_ATTEMPT_LOCKOUT_SECONDS=1800
OTP_TTL_SECONDS=300

# -- Internal ------------------------------------------------------------------
INTERNAL_API_SECRET=change-me-in-production

# -- Kafka ---------------------------------------------------------------------
# EVENT_DRIVER=kafka is REQUIRED for OTP / password reset / register flows
# (mail.send events are published to notification-service via Kafka).
# Setting EVENT_DRIVER=local will make those endpoints fail with 503.
EVENT_DRIVER=kafka
KAFKA_BROKERS=localhost:9093
KAFKA_GROUP_ID=auth-service

# -- Observability -------------------------------------------------------------
# Leave blank to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
