# ── App ──────────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development
GLOBAL_PREFIX=api
CORS_ORIGINS=*
APP_URL=http://localhost:3002

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:secret@localhost:5433/auth_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Leave blank in dev → ephemeral key pair generated on startup
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=auth-service
JWT_AUDIENCE=comic-platform

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3002/api/auth/google/callback
GOOGLE_FRONTEND_URL=http://localhost:3000

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@comic-platform.com

# ── Kafka ─────────────────────────────────────────────────────────────────────
# EVENT_DRIVER=local  → in-process events (no Kafka needed)
# EVENT_DRIVER=kafka  → publish via Kafka broker
KAFKA_BROKERS=localhost:9093
EVENT_DRIVER=local

# ── Security ──────────────────────────────────────────────────────────────────
INTERNAL_API_SECRET=change-me-in-production
SECURITY_ATTEMPT_MAX=5
SECURITY_ATTEMPT_WINDOW_SECONDS=900
SECURITY_ATTEMPT_LOCKOUT_SECONDS=1800

# ── JWT Guard (self) ──────────────────────────────────────────────────────────
AUTH_JWKS_URL=http://localhost:3002/.well-known/jwks.json

# ── Observability ─────────────────────────────────────────────────────────────
# Leave blank to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
