# =============================================================================
# Auth Service — Environment Variables
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
SERVICE_NAME=Auth Service
PORT=3001
NODE_ENV=development
GLOBAL_PREFIX=api
APP_URL=http://localhost:3001
APP_TIMEZONE=Asia/Ho_Chi_Minh
CORS_ORIGINS=*

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:secret@localhost:5432/auth_db?connection_limit=5

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required in production (token revocation, rate limiting)
REDIS_URL=redis://localhost:6379

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Leave blank in dev → ephemeral key pair generated on startup
# Required in production
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=auth-service
JWT_AUDIENCE=comic-platform

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Leave blank to disable Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
GOOGLE_FRONTEND_URL=http://localhost:3000
# Required in production when Google OAuth is enabled (min 32 chars)
GOOGLE_OAUTH_STATE_SECRET=

# ── Security ──────────────────────────────────────────────────────────────────
# Required in production (min 16 chars)
INTERNAL_API_SECRET=change-me-in-production
SECURITY_ATTEMPT_MAX=5
SECURITY_ATTEMPT_WINDOW_SECONDS=900
SECURITY_ATTEMPT_LOCKOUT_SECONDS=1800
OTP_TTL_SECONDS=300
BCRYPT_ROUNDS=12

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Required for OTP / password reset / register flows
# (mail.send events are published to notification-service via Kafka)
EVENT_DRIVER=kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=auth-service

# ── Logging ───────────────────────────────────────────────────────────────────
# Target: console | file | file,console (default: console)
LOG_TARGET=file,console
LOG_DIR=./logs
# Levels: fatal, error, warn, info, debug, verbose
LOG_LEVEL=info

# ── Observability ─────────────────────────────────────────────────────────────
# Leave blank to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=
