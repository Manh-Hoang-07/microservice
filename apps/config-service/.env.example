# =============================================================================
# Config Service
# =============================================================================

# -- App -----------------------------------------------------------------------
SERVICE_NAME=Config Service
PORT=3003
APP_URL=http://localhost:3003
APP_TIMEZONE=Asia/Ho_Chi_Minh
NODE_ENV=development
GLOBAL_PREFIX=api
CORS_ORIGINS=*

# -- PostgreSQL ----------------------------------------------------------------
DATABASE_URL=postgresql://postgres:secret@localhost:5436/config_db

# -- JWT Guard (consumer) ------------------------------------------------------
AUTH_JWKS_URL=http://localhost:3001/.well-known/jwks.json

# -- Internal ------------------------------------------------------------------
INTERNAL_API_SECRET=change-me-in-production

# -- Observability -------------------------------------------------------------
# Leave blank to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
