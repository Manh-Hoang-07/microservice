# =============================================================================
# Config Service — Example / Reference
# Priority: .env.local > .env.production > .env
# Copy relevant vars to .env.local (gitignored) and fill in real values.
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
SERVICE_NAME=Config Service
PORT=3003
NODE_ENV=development
GLOBAL_PREFIX=api/config
APP_URL=http://localhost:3003
APP_TIMEZONE=Asia/Ho_Chi_Minh
CORS_ORIGINS=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:secret@localhost:5436/config_db?connection_limit=20&pool_timeout=60

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_JWKS_URL=http://localhost/.well-known/jwks.json

# ── IAM ───────────────────────────────────────────────────────────────────────
IAM_INTERNAL_URL=http://localhost/api/iam

# ── Internal ──────────────────────────────────────────────────────────────────
INTERNAL_API_SECRET=change-me-in-production-min-16-chars

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
