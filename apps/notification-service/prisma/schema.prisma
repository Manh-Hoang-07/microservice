generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Notification {
  id              BigInt    @id @default(autoincrement())
  user_id         BigInt
  title           String    @db.VarChar(255)
  message         String    @db.Text
  type            String    @default("info") @db.VarChar(30)
  data            Json?
  is_read         Boolean   @default(false)
  read_at         DateTime? @db.Timestamp(0)
  status          String    @default("active") @db.VarChar(30)
  created_at      DateTime  @default(now()) @db.Timestamp(0)
  updated_at      DateTime  @updatedAt @db.Timestamp(0)

  @@index([user_id], map: "notifications_idx_user_id")
  @@index([status], map: "notifications_idx_status")
  @@index([type], map: "notifications_idx_type")
  @@index([is_read], map: "notifications_idx_is_read")
  @@index([user_id, is_read], map: "notifications_idx_user_read")
  @@map("notifications")
}

model ContentTemplate {
  id        BigInt   @id @default(autoincrement())
  code      String   @unique @db.VarChar(100)
  name      String   @db.VarChar(255)
  category  String   @default("render") @db.VarChar(30)
  type      String   @db.VarChar(30)
  content   String?  @db.Text
  file_path String?  @db.VarChar(500)
  metadata  Json?
  variables Json?
  status    String   @default("active") @db.VarChar(30)
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt @db.Timestamp(0)

  @@index([code], map: "idx_content_templates_code")
  @@index([status], map: "idx_content_templates_status")
  @@index([category], map: "idx_content_templates_category")
  @@index([type], map: "idx_content_templates_type")
  @@map("content_templates")
}

model ComicFollowersProjection {
  id          BigInt   @id @default(autoincrement())
  user_id     BigInt
  comic_id    BigInt
  followed_at DateTime @default(now()) @db.Timestamp(0)

  @@unique([user_id, comic_id], map: "cfp_idx_user_comic")
  @@index([comic_id], map: "cfp_idx_comic_id")
  @@index([user_id], map: "cfp_idx_user_id")
  @@map("comic_followers_projection")
}
