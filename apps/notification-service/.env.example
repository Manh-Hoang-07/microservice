# -- App -----------------------------------------------------------------------
PORT=3004
NODE_ENV=development
GLOBAL_PREFIX=api
CORS_ORIGINS=*

# -- PostgreSQL ----------------------------------------------------------------
DATABASE_URL=postgresql://postgres:secret@localhost:5435/notif_db

# -- Redis ---------------------------------------------------------------------
REDIS_URL=redis://localhost:6382

# -- JWT Guard -----------------------------------------------------------------
AUTH_JWKS_URL=http://localhost:3002/.well-known/jwks.json

# -- Kafka ---------------------------------------------------------------------
KAFKA_BROKERS=localhost:9093
KAFKA_GROUP_ID=notification-service

# -- Email (SMTP) --------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@comic-platform.com

# -- Observability -------------------------------------------------------------
# Leave blank to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
