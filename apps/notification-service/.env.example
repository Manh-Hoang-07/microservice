# =============================================================================
# Notification Service
# =============================================================================

# -- App -----------------------------------------------------------------------
SERVICE_NAME=Notification Service
PORT=3005
APP_URL=http://localhost:3005
APP_TIMEZONE=Asia/Ho_Chi_Minh
NODE_ENV=development
GLOBAL_PREFIX=api
CORS_ORIGINS=*

# -- PostgreSQL ----------------------------------------------------------------
DATABASE_URL=postgresql://postgres:secret@localhost:5435/notification_db?connection_limit=5

# -- Redis ---------------------------------------------------------------------
REDIS_URL=redis://localhost:6382

# -- JWT Guard (consumer) ------------------------------------------------------
AUTH_JWKS_URL=http://localhost:3001/.well-known/jwks.json

# -- Upstream services ---------------------------------------------------------
CONFIG_INTERNAL_URL=http://localhost:3003

# -- Internal ------------------------------------------------------------------
INTERNAL_API_SECRET=change-me-in-production

# -- Kafka ---------------------------------------------------------------------
KAFKA_BROKERS=localhost:9093
KAFKA_GROUP_ID=notification-service

# -- Observability -------------------------------------------------------------
# Leave blank to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
