# -- App -----------------------------------------------------------------------
SERVICE_NAME=Notification Service
PORT=3004
APP_URL=http://localhost:3004
APP_TIMEZONE=Asia/Ho_Chi_Minh
NODE_ENV=development
GLOBAL_PREFIX=api
CORS_ORIGINS=*

# -- PostgreSQL ----------------------------------------------------------------
DATABASE_URL=postgresql://postgres:secret@localhost:5435/notif_db

# -- Redis ---------------------------------------------------------------------
REDIS_URL=redis://localhost:6382

# -- JWT Guard -----------------------------------------------------------------
AUTH_JWKS_URL=http://localhost:3002/.well-known/jwks.json

# -- Internal ------------------------------------------------------------------
CONFIG_INTERNAL_URL=http://localhost:3007
INTERNAL_SECRET=internal-secret-key

# -- Kafka ---------------------------------------------------------------------
KAFKA_BROKERS=localhost:9093
KAFKA_GROUP_ID=notification-service

# -- Observability -------------------------------------------------------------
# Leave blank to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
