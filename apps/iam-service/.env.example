# -- App -----------------------------------------------------------------------
SERVICE_NAME=IAM Service
PORT=3008
APP_URL=http://localhost:3008
APP_TIMEZONE=Asia/Ho_Chi_Minh
NODE_ENV=development
GLOBAL_PREFIX=api
CORS_ORIGINS=*

# -- PostgreSQL ----------------------------------------------------------------
DATABASE_URL=postgresql://postgres:secret@localhost:5441/iam_db

# -- Redis ---------------------------------------------------------------------
REDIS_URL=redis://localhost:6385

# -- JWT Guard -----------------------------------------------------------------
AUTH_JWKS_URL=http://localhost:3002/.well-known/jwks.json

# -- Internal ------------------------------------------------------------------
INTERNAL_API_SECRET=change-me-in-production

# -- RBAC ----------------------------------------------------------------------
RBAC_CACHE_TTL=86400

# -- Observability -------------------------------------------------------------
# Leave blank to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
