# =============================================================================
# Introduction Service
# =============================================================================

# -- App -----------------------------------------------------------------------
SERVICE_NAME=Introduction Service
PORT=3010
APP_URL=http://localhost:3010
APP_TIMEZONE=Asia/Ho_Chi_Minh
NODE_ENV=development
GLOBAL_PREFIX=api
CORS_ORIGINS=*

# -- PostgreSQL ----------------------------------------------------------------
DATABASE_URL=postgresql://postgres:secret@localhost:5439/introduction_db

# -- JWT Guard (consumer) ------------------------------------------------------
AUTH_JWKS_URL=http://localhost:3002/.well-known/jwks.json

# -- Internal ------------------------------------------------------------------
INTERNAL_API_SECRET=change-me-in-production

# -- Observability -------------------------------------------------------------
# Leave blank to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
