# -- App -----------------------------------------------------------------------
PORT=3008
NODE_ENV=development
GLOBAL_PREFIX=api
CORS_ORIGINS=*

# -- PostgreSQL ----------------------------------------------------------------
DATABASE_URL=postgresql://postgres:secret@localhost:5439/introduction_db

