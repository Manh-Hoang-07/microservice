generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id              BigInt   @id @default(autoincrement())
  name            String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(255)
  description     String?  @db.Text
  parent_id       BigInt?
  is_active       Boolean  @default(true)
  sort_order      Int      @default(0)
  seo_title       String?  @db.VarChar(255)
  seo_description String?  @db.Text
  seo_keywords    String?  @db.VarChar(500)
  created_user_id BigInt?
  updated_user_id BigInt?
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @updatedAt @db.Timestamp(0)
  group_id        BigInt?

  parent   Category?      @relation("CategoryToChildren", fields: [parent_id], references: [id], onDelete: SetNull)
  children Category[]     @relation("CategoryToChildren")
  posts    PostCategory[]

  @@index([slug], map: "categories_idx_slug")
  @@index([name], map: "categories_idx_name")
  @@index([parent_id], map: "categories_idx_parent_id")
  @@index([is_active], map: "categories_idx_is_active")
  @@index([sort_order], map: "categories_idx_sort_order")
  @@index([created_at], map: "categories_idx_created_at")
  @@index([created_user_id], map: "categories_idx_created_user_id")
  @@index([updated_user_id], map: "categories_idx_updated_user_id")
  @@index([group_id], map: "categories_idx_group_id")
  @@map("categories")
}

model Tag {
  id              BigInt   @id @default(autoincrement())
  name            String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(255)
  description     String?  @db.Text
  is_active       Boolean  @default(true)
  created_user_id BigInt?
  updated_user_id BigInt?
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @updatedAt @db.Timestamp(0)
  group_id        BigInt?

  posts PostTag[]

  @@index([slug], map: "tags_idx_slug")
  @@index([name], map: "tags_idx_name")
  @@index([is_active], map: "tags_idx_is_active")
  @@index([created_at], map: "tags_idx_created_at")
  @@index([created_user_id], map: "tags_idx_created_user_id")
  @@index([updated_user_id], map: "tags_idx_updated_user_id")
  @@index([group_id], map: "tags_idx_group_id")
  @@map("tags")
}

model Post {
  id              BigInt    @id @default(autoincrement())
  name            String    @db.VarChar(255)
  slug            String    @unique @db.VarChar(255)
  excerpt         String?   @db.Text
  content         String?   @db.Text
  image           String?   @db.VarChar(500)
  cover_image     String?   @db.VarChar(500)
  status          String    @default("draft") @db.VarChar(30)
  post_type       String    @default("text") @db.VarChar(30)
  video_url       String?   @db.VarChar(500)
  audio_url       String?   @db.VarChar(500)
  is_featured     Boolean   @default(false)
  is_pinned       Boolean   @default(false)
  published_at    DateTime? @db.Timestamp(0)
  seo_title       String?   @db.VarChar(255)
  seo_description String?   @db.Text
  seo_keywords    String?   @db.VarChar(500)
  created_user_id BigInt?
  updated_user_id BigInt?
  created_at      DateTime  @default(now()) @db.Timestamp(0)
  updated_at      DateTime  @updatedAt @db.Timestamp(0)
  group_id        BigInt?

  stats         Stats?
  daily_stats   DailyStats[]
  categoryLinks PostCategory[]
  tagLinks      PostTag[]
  comments      Comment[]

  @@index([slug], map: "posts_idx_slug")
  @@index([status], map: "posts_idx_status")
  @@index([post_type], map: "posts_idx_post_type")
  @@index([is_featured], map: "posts_idx_is_featured")
  @@index([is_pinned], map: "posts_idx_is_pinned")
  @@index([published_at], map: "posts_idx_published_at")
  // Composite index for the public list. Filter is `status IN (...)` and
  // ordering is by `published_at DESC` — without this composite, Postgres
  // can use only one of the two single-column indexes per query.
  @@index([status, published_at(sort: Desc)], map: "posts_idx_status_published_at")
  @@index([created_at], map: "posts_idx_created_at")
  @@index([created_user_id], map: "posts_idx_created_user_id")
  @@index([updated_user_id], map: "posts_idx_updated_user_id")
  @@index([group_id], map: "posts_idx_group_id")
  @@map("posts")
}

model Stats {
  post_id    BigInt   @id
  view_count BigInt   @default(0)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp(0)

  post Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@index([view_count], map: "stats_idx_view_count")
  @@index([updated_at], map: "stats_idx_updated_at")
  @@map("stats")
}

model DailyStats {
  post_id    BigInt
  stat_date  DateTime @db.Date
  view_count BigInt   @default(0)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp(0)

  post Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@id([post_id, stat_date])
  @@index([stat_date], map: "daily_stats_idx_stat_date")
  @@index([view_count], map: "daily_stats_idx_view_count")
  @@map("daily_stats")
}

model PostCategory {
  post_id     BigInt
  category_id BigInt

  post     Post     @relation(fields: [post_id], references: [id], onDelete: Cascade)
  category Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@id([post_id, category_id])
  @@index([category_id], map: "post_categories_idx_category_id")
  @@map("post_categories")
}

model PostTag {
  post_id BigInt
  tag_id  BigInt

  post Post @relation(fields: [post_id], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([post_id, tag_id])
  @@index([tag_id], map: "post_tags_idx_tag_id")
  @@map("post_tags")
}

model Comment {
  id              BigInt   @id @default(autoincrement())
  user_id         BigInt?
  post_id         BigInt
  parent_id       BigInt?
  guest_name      String?  @db.VarChar(255)
  guest_email     String?  @db.VarChar(255)
  content         String   @db.Text
  status          String   @default("visible") @db.VarChar(30)
  created_user_id BigInt?
  updated_user_id BigInt?
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @updatedAt @db.Timestamp(0)

  post    Post      @relation(fields: [post_id], references: [id], onDelete: Cascade)
  // SetNull (was Cascade): admin hard-delete of one parent comment used to
  // wipe the entire reply subtree even though user-side delete already
  // soft-deletes via status='deleted'. Replies now survive with parent_id
  // = NULL; the renderer can display "[deleted]" for missing parents.
  parent  Comment?  @relation("CommentToReplies", fields: [parent_id], references: [id], onDelete: SetNull)
  replies Comment[] @relation("CommentToReplies")

  @@index([user_id], map: "comments_idx_user_id")
  @@index([post_id], map: "comments_idx_post_id")
  @@index([parent_id], map: "comments_idx_parent_id")
  @@index([status], map: "comments_idx_status")
  @@index([created_at], map: "comments_idx_created_at")
  @@index([post_id, created_at], map: "comments_idx_post_created")
  @@index([guest_email], map: "comments_idx_guest_email")
  @@index([created_user_id], map: "comments_idx_created_user_id")
  @@index([updated_user_id], map: "comments_idx_updated_user_id")
  @@map("comments")
}

model Outbox {
  id         BigInt   @id @default(autoincrement())
  event_type String   @db.VarChar(100)
  payload    Json
  published  Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz()

  @@index([published, created_at], map: "outbox_idx_unpublished")
  @@map("outbox")
}
