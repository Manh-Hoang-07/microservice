# =============================================================================
# Comic Service — Example / Reference
# Priority: .env.local > .env.production > .env
# Copy relevant vars to .env.local (gitignored) and fill in real values.
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
SERVICE_NAME=Comic Service
PORT=3009
NODE_ENV=development
GLOBAL_PREFIX=api/comics
APP_URL=http://localhost:3009
APP_TIMEZONE=Asia/Ho_Chi_Minh
CORS_ORIGINS=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:secret@localhost:5434/comic_db?connection_limit=20&pool_timeout=60

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6381

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_JWKS_URL=http://localhost:3001/.well-known/jwks.json

# ── IAM ───────────────────────────────────────────────────────────────────────
IAM_INTERNAL_URL=http://localhost:3002/api/iam

# ── Internal ──────────────────────────────────────────────────────────────────
INTERNAL_API_SECRET=change-me-in-production-min-16-chars

# ── Messaging ─────────────────────────────────────────────────────────────────
# local: no broker (default for dev/serverless)
# redis: Redis Streams
# rabbitmq: RabbitMQ cluster
# kafka: Kafka cluster (Aiven, Confluent, ...)
EVENT_DRIVER=local

# Redis Streams (dùng khi EVENT_DRIVER=redis)
REDIS_EVENT_URL=redis://localhost:6380
REDIS_STREAM_MAX_LEN=10000

# RabbitMQ (dùng khi EVENT_DRIVER=rabbitmq)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Kafka (dùng khi EVENT_DRIVER=kafka)
KAFKA_BROKERS=localhost:9092
KAFKA_LINGER_MS=100
KAFKA_BATCH_SIZE=32768
KAFKA_COMPRESSION=snappy
KAFKA_GROUP_ID=comic-service
KAFKA_REPLICATION_FACTOR=3
# SSL for Aiven Kafka — leave empty for local plaintext
KAFKA_CA_CERTIFICATE=
KAFKA_ACCESS_CERTIFICATE=
KAFKA_ACCESS_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
