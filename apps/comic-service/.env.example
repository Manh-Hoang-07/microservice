PORT=3001
NODE_ENV=development
GLOBAL_PREFIX=api
CORS_ORIGINS=*

# PostgreSQL
DATABASE_URL=postgresql://postgres:secret@localhost:5434/comic_db

# Redis
REDIS_URL=redis://localhost:6381

# Auth Service JWKS
AUTH_JWKS_URL=http://localhost:3002/api/.well-known/jwks.json

# Kafka
KAFKA_BROKERS=localhost:9093
EVENT_DRIVER=local

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
