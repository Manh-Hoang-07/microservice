# =============================================================================
# Comic Service
# =============================================================================

# -- App -----------------------------------------------------------------------
SERVICE_NAME=Comic Service
PORT=3001
APP_URL=http://localhost:3001
APP_TIMEZONE=Asia/Ho_Chi_Minh
NODE_ENV=development
GLOBAL_PREFIX=api
CORS_ORIGINS=*

# -- PostgreSQL ----------------------------------------------------------------
DATABASE_URL=postgresql://postgres:secret@localhost:5434/comic_db

# -- Redis ---------------------------------------------------------------------
REDIS_URL=redis://localhost:6381

# -- JWT Guard (consumer) ------------------------------------------------------
AUTH_JWKS_URL=http://localhost:3002/.well-known/jwks.json

# -- Internal ------------------------------------------------------------------
INTERNAL_API_SECRET=change-me-in-production

# -- Kafka ---------------------------------------------------------------------
EVENT_DRIVER=local
KAFKA_BROKERS=localhost:9093

# -- Observability -------------------------------------------------------------
# Leave blank to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
