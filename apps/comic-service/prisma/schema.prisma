generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Comic {
  id                      BigInt    @id @default(autoincrement())
  slug                    String    @unique @db.VarChar(255)
  title                   String    @db.VarChar(255)
  description             String?   @db.Text
  cover_image             String?   @db.VarChar(500)
  author                  String?   @db.VarChar(255)
  status                  String    @default("draft") @db.VarChar(30)
  created_user_id         BigInt?
  updated_user_id         BigInt?
  created_at              DateTime  @default(now()) @db.Timestamp(0)
  updated_at              DateTime  @updatedAt @db.Timestamp(0)
  last_chapter_id         BigInt?
  last_chapter_updated_at DateTime? @db.Timestamp(0)
  is_featured             Boolean   @default(false)
  group_id                BigInt?

  stats             ComicStats?
  daily_stats       ComicDailyStats[]
  chapters          Chapter[]
  lastChapter       Chapter?               @relation("LastChapter", fields: [last_chapter_id], references: [id], onDelete: SetNull)
  categoryLinks     ComicCategoryOnComic[]
  comments          ComicComment[]
  reviews           ComicReview[]
  views             ComicView[]
  follows           ComicFollow[]
  reading_histories ReadingHistory[]

  @@index([slug], map: "comics_idx_slug")
  @@index([status], map: "comics_idx_status")
  @@index([author], map: "comics_idx_author")
  @@index([created_at], map: "comics_idx_created_at")
  @@index([created_user_id], map: "comics_idx_created_user_id")
  @@index([updated_user_id], map: "comics_idx_updated_user_id")
  @@index([last_chapter_updated_at], map: "comics_idx_last_chapter_updated_at")
  @@index([is_featured], map: "comics_idx_is_featured")
  @@index([group_id], map: "comics_idx_comics_group_id")
  @@map("comics")
}

model ComicStats {
  comic_id     BigInt   @id
  view_count   BigInt   @default(0)
  follow_count BigInt   @default(0)
  rating_count BigInt   @default(0)
  rating_sum   BigInt   @default(0)
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamp(0)

  comic Comic @relation(fields: [comic_id], references: [id], onDelete: Cascade)

  @@index([view_count], map: "comic_stats_idx_view_count")
  @@index([follow_count], map: "comic_stats_idx_follow_count")
  @@index([updated_at], map: "comic_stats_idx_updated_at")
  @@map("comic_stats")
}

model ComicDailyStats {
  comic_id   BigInt
  stat_date  DateTime @db.Date
  view_count BigInt   @default(0)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp(0)

  comic Comic @relation(fields: [comic_id], references: [id], onDelete: Cascade)

  @@id([comic_id, stat_date])
  @@index([stat_date], map: "comic_daily_stats_idx_stat_date")
  @@index([view_count], map: "comic_daily_stats_idx_view_count")
  @@map("comic_daily_stats")
}

model Chapter {
  id              BigInt   @id @default(autoincrement())
  comic_id        BigInt
  team_id         BigInt?
  title           String   @db.VarChar(255)
  chapter_index   Int
  chapter_label   String?  @db.VarChar(50)
  status          String   @default("draft") @db.VarChar(30)
  view_count      BigInt   @default(0)
  created_user_id BigInt?
  updated_user_id BigInt?
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @updatedAt @db.Timestamp(0)
  group_id        BigInt?

  comic             Comic            @relation(fields: [comic_id], references: [id], onDelete: Cascade)
  comicsLastChapter Comic[]          @relation("LastChapter")
  pages             ChapterPage[]
  views             ComicView[]
  comments          ComicComment[]
  reading_histories ReadingHistory[]
  bookmarks         Bookmark[]

  @@unique([comic_id, chapter_index], map: "chapters_idx_comic_chapter_unique")
  @@index([comic_id], map: "chapters_idx_comic_id")
  @@index([comic_id, chapter_index], map: "chapters_idx_comic_chapter_index")
  @@index([team_id], map: "chapters_idx_team_id")
  @@index([status], map: "chapters_idx_status")
  @@index([view_count], map: "chapters_idx_view_count")
  @@index([created_at], map: "chapters_idx_created_at")
  @@index([created_user_id], map: "chapters_idx_created_user_id")
  @@index([updated_user_id], map: "chapters_idx_updated_user_id")
  @@index([group_id], map: "chapters_idx_chapters_group_id")
  @@map("chapters")
}

model ComicCategory {
  id              BigInt   @id @default(autoincrement())
  name            String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(255)
  description     String?  @db.Text
  created_user_id BigInt?
  updated_user_id BigInt?
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @updatedAt @db.Timestamp(0)
  group_id        BigInt?

  comics ComicCategoryOnComic[]

  @@index([slug], map: "comic_categories_idx_slug")
  @@index([name], map: "comic_categories_idx_name")
  @@index([created_at], map: "comic_categories_idx_created_at")
  @@index([created_user_id], map: "comic_categories_idx_created_user_id")
  @@index([updated_user_id], map: "comic_categories_idx_updated_user_id")
  @@index([group_id], map: "comic_categories_idx_comic_categories_group_id")
  @@map("comic_categories")
}

model ComicCategoryOnComic {
  comic_id          BigInt
  comic_category_id BigInt
  comic             Comic         @relation(fields: [comic_id], references: [id], onDelete: Cascade)
  category          ComicCategory @relation(fields: [comic_category_id], references: [id], onDelete: Cascade)

  @@id([comic_id, comic_category_id])
  @@map("comic_category")
}

model ComicComment {
  id              BigInt   @id @default(autoincrement())
  user_id         BigInt
  comic_id        BigInt
  chapter_id      BigInt?
  parent_id       BigInt?
  content         String   @db.Text
  status          String   @default("visible") @db.VarChar(30)
  created_user_id BigInt?
  updated_user_id BigInt?
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @updatedAt @db.Timestamp(0)

  comic   Comic          @relation(fields: [comic_id], references: [id], onDelete: Cascade)
  chapter Chapter?       @relation(fields: [chapter_id], references: [id], onDelete: SetNull)
  parent  ComicComment?  @relation("CommentToReplies", fields: [parent_id], references: [id], onDelete: Cascade)
  replies ComicComment[] @relation("CommentToReplies")

  @@index([user_id], map: "comic_comments_idx_comic_comments_user_id")
  @@index([comic_id], map: "comic_comments_idx_comic_comments_comic_id")
  @@index([chapter_id], map: "comic_comments_idx_comic_comments_chapter_id")
  @@index([parent_id], map: "comic_comments_idx_comic_comments_parent_id")
  @@index([status], map: "comic_comments_idx_status")
  @@index([created_at], map: "comic_comments_idx_created_at")
  @@index([comic_id, created_at], map: "comic_comments_idx_comic_created")
  @@index([chapter_id, created_at], map: "comic_comments_idx_chapter_created")
  @@index([created_user_id], map: "comic_comments_idx_created_user_id")
  @@index([updated_user_id], map: "comic_comments_idx_updated_user_id")
  @@map("comic_comments")
}

model ComicReview {
  id              BigInt   @id @default(autoincrement())
  user_id         BigInt
  comic_id        BigInt
  rating          Int      @db.SmallInt
  content         String?  @db.Text
  created_user_id BigInt?
  updated_user_id BigInt?
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @updatedAt @db.Timestamp(0)

  comic Comic @relation(fields: [comic_id], references: [id], onDelete: Cascade)

  @@unique([user_id, comic_id], map: "comic_reviews_idx_user_comic")
  @@index([user_id], map: "comic_reviews_idx_user_id")
  @@index([comic_id], map: "comic_reviews_idx_comic_id")
  @@index([rating], map: "comic_reviews_idx_rating")
  @@index([created_at], map: "comic_reviews_idx_created_at")
  @@index([created_user_id], map: "comic_reviews_idx_created_user_id")
  @@index([updated_user_id], map: "comic_reviews_idx_updated_user_id")
  @@map("comic_reviews")
}

model ChapterPage {
  id          BigInt   @id @default(autoincrement())
  chapter_id  BigInt
  page_number Int
  image_url   String   @db.VarChar(500)
  width       Int?
  height      Int?
  file_size   BigInt?
  created_at  DateTime @default(now()) @db.Timestamp(0)

  chapter Chapter @relation(fields: [chapter_id], references: [id], onDelete: Cascade)

  @@unique([chapter_id, page_number], map: "chapter_pages_idx_chapter_page_unique")
  @@index([chapter_id], map: "chapter_pages_idx_chapter_id")
  @@index([chapter_id, page_number], map: "chapter_pages_idx_chapter_page")
  @@map("chapter_pages")
}

model ComicView {
  id         BigInt   @id @default(autoincrement())
  comic_id   BigInt
  chapter_id BigInt?
  user_id    BigInt?
  ip         String?  @db.VarChar(45)
  user_agent String?  @db.VarChar(500)
  created_at DateTime @default(now()) @db.Timestamp(0)

  comic   Comic    @relation(fields: [comic_id], references: [id], onDelete: Cascade)
  chapter Chapter? @relation(fields: [chapter_id], references: [id], onDelete: SetNull)

  @@index([comic_id], map: "comic_views_idx_comic_views_comic_id")
  @@index([chapter_id], map: "comic_views_idx_comic_views_chapter_id")
  @@index([user_id], map: "comic_views_idx_comic_views_user_id")
  @@index([created_at], map: "comic_views_idx_created_at")
  @@index([comic_id, created_at], map: "comic_views_idx_comic_created")
  @@index([chapter_id, created_at], map: "comic_views_idx_chapter_created")
  @@map("comic_views")
}

model ComicFollow {
  id         BigInt   @id @default(autoincrement())
  user_id    BigInt
  comic_id   BigInt
  created_at DateTime @default(now()) @db.Timestamp(0)

  comic Comic @relation(fields: [comic_id], references: [id], onDelete: Cascade)

  @@unique([user_id, comic_id], map: "comic_follows_idx_user_comic")
  @@index([user_id], map: "comic_follows_idx_comic_follows_user_id")
  @@index([comic_id], map: "comic_follows_idx_comic_follows_comic_id")
  @@index([created_at], map: "comic_follows_idx_created_at")
  @@map("comic_follows")
}

model ReadingHistory {
  id         BigInt   @id @default(autoincrement())
  user_id    BigInt
  comic_id   BigInt
  chapter_id BigInt
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @updatedAt @db.Timestamp(0)

  comic   Comic   @relation(fields: [comic_id], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapter_id], references: [id], onDelete: Cascade)

  @@unique([user_id, comic_id], map: "reading_histories_idx_user_comic")
  @@index([user_id], map: "reading_histories_idx_reading_histories_user_id")
  @@index([comic_id], map: "reading_histories_idx_reading_histories_comic_id")
  @@index([chapter_id], map: "reading_histories_idx_reading_histories_chapter_id")
  @@index([updated_at], map: "reading_histories_idx_updated_at")
  @@map("reading_histories")
}

model Bookmark {
  id          BigInt   @id @default(autoincrement())
  user_id     BigInt
  chapter_id  BigInt
  page_number Int
  created_at  DateTime @default(now()) @db.Timestamp(0)

  chapter Chapter @relation(fields: [chapter_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "bookmarks_idx_bookmarks_user_id")
  @@index([chapter_id], map: "bookmarks_idx_bookmarks_chapter_id")
  @@index([user_id, chapter_id], map: "bookmarks_idx_user_chapter")
  @@index([created_at], map: "bookmarks_idx_created_at")
  @@map("bookmarks")
}

model ComicOutbox {
  id         BigInt   @id @default(autoincrement())
  event_type String   @db.VarChar(100)
  payload    Json
  published  Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz()

  @@index([published, created_at], map: "comic_outbox_idx_unpublished")
  @@map("comic_outbox")
}
