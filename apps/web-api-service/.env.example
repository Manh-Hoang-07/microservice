# =============================================================================
# Web API (Gateway) Service — Example / Reference
# Priority: .env.local > .env.production > .env
# Copy relevant vars to .env.local (gitignored) and fill in real values.
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
SERVICE_NAME=Gateway Service
PORT=3010
NODE_ENV=development
GLOBAL_PREFIX=api/web
APP_URL=http://localhost:3010
APP_TIMEZONE=Asia/Ho_Chi_Minh
CORS_ORIGINS=http://localhost:3000

# ── Redis (cache — leave blank to disable) ────────────────────────────────────
REDIS_URL=redis://localhost:6383

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_JWKS_URL=http://localhost/.well-known/jwks.json

# ── Upstream services ────────────────────────────────────────────────────────
COMIC_SERVICE_URL=http://localhost:3009/api/comics
POST_SERVICE_URL=http://localhost:3008/api/posts
SERVICE_TIMEOUT_MS=5000

# ── Internal ──────────────────────────────────────────────────────────────────
INTERNAL_API_SECRET=change-me-in-production-min-16-chars

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

JWT_ISSUER="token-provider"
JWT_AUDIENCE="token-consumer"
