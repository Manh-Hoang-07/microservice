# =============================================================================
# Web API Service (Gateway) — Environment Variables
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
SERVICE_NAME=Gateway Service
PORT=3010
NODE_ENV=development
GLOBAL_PREFIX=api/web
APP_URL=http://localhost:3010
APP_TIMEZONE=Asia/Ho_Chi_Minh
CORS_ORIGINS=*

# ── Redis (cache) ────────────────────────────────────────────────────────────
# Leave blank → caching disabled
REDIS_URL=redis://localhost:6383

# ── Auth ──────────────────────────────────────────────────────────────────────
# Leave blank in dev → guard bypasses auth (sets user = { sub: 'dev' })
AUTH_JWKS_URL=http://localhost:3001/.well-known/jwks.json
INTERNAL_API_SECRET=change-me-in-production

# ── Upstream services ────────────────────────────────────────────────────────
COMIC_SERVICE_URL=http://localhost:3009/api/comics
POST_SERVICE_URL=http://localhost:3008/api/posts
SERVICE_TIMEOUT_MS=5000

# ── Observability ─────────────────────────────────────────────────────────────
# Leave blank to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
