# =============================================================================
# Storage Service
# =============================================================================

# -- App -----------------------------------------------------------------------
SERVICE_NAME=Storage Service
PORT=3003
APP_URL=http://localhost:3003
APP_TIMEZONE=Asia/Ho_Chi_Minh
NODE_ENV=development
GLOBAL_PREFIX=api
CORS_ORIGINS=*

# -- JWT Guard (consumer) ------------------------------------------------------
# Leave blank in dev → guard bypasses auth
AUTH_JWKS_URL=http://localhost:3002/.well-known/jwks.json

# -- Storage backend -----------------------------------------------------------
# Options: local | s3 | cloudinary
STORAGE_TYPE=local
STORAGE_MAX_FILE_SIZE=10485760
STORAGE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif

# Local
STORAGE_LOCAL_PATH=./storage/uploads
STORAGE_LOCAL_BASE_URL=/api/upload

# S3 / MinIO
STORAGE_S3_REGION=us-east-1
STORAGE_S3_BUCKET=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_ENDPOINT=
STORAGE_S3_BASE_URL=
STORAGE_S3_FORCE_PATH_STYLE=true

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -- Internal ------------------------------------------------------------------
INTERNAL_API_SECRET=change-me-in-production

# -- Observability -------------------------------------------------------------
# Leave blank to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
