# =============================================================================
# Storage Service — Example / Reference
# Priority: .env.local > .env.production > .env
# Copy relevant vars to .env.local (gitignored) and fill in real values.
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
SERVICE_NAME=Storage Service
PORT=3004
NODE_ENV=development
GLOBAL_PREFIX=api/storage
APP_URL=http://localhost:3004
APP_TIMEZONE=Asia/Ho_Chi_Minh
CORS_ORIGINS=http://localhost:3000

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_JWKS_URL=http://localhost/.well-known/jwks.json

# ── IAM ───────────────────────────────────────────────────────────────────────
IAM_INTERNAL_URL=http://localhost/api/iam

# ── Internal ──────────────────────────────────────────────────────────────────
INTERNAL_API_SECRET=change-me-in-production-min-16-chars

# ── Redis (optional — enables caching) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Storage backend ──────────────────────────────────────────────────────────
# Options: local | s3 | cloudinary
STORAGE_TYPE=local
STORAGE_MAX_FILE_SIZE=10485760
STORAGE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif

# Local storage (default for development)
STORAGE_LOCAL_PATH=./storage/uploads
STORAGE_LOCAL_BASE_URL=http://localhost/api/storage/upload

# S3 / MinIO (required when STORAGE_TYPE=s3)
STORAGE_S3_REGION=ap-northeast-1
STORAGE_S3_BUCKET=my-bucket
STORAGE_S3_ACCESS_KEY_ID=your-access-key-id
STORAGE_S3_SECRET_ACCESS_KEY=your-secret-access-key
STORAGE_S3_ENDPOINT=https://your-endpoint.example.com
STORAGE_S3_BASE_URL=https://your-public-base-url.example.com
STORAGE_S3_FORCE_PATH_STYLE=true

# Cloudinary (required when STORAGE_TYPE=cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
