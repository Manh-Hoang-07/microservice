# =============================================================================
# BFF Service
# =============================================================================

# -- App -----------------------------------------------------------------------
SERVICE_NAME=BFF Service
PORT=3006
APP_URL=http://localhost:3006
APP_TIMEZONE=Asia/Ho_Chi_Minh
NODE_ENV=development
GLOBAL_PREFIX=api
CORS_ORIGINS=*

# -- Redis (cache) -------------------------------------------------------------
# Leave blank → caching disabled
BFF_REDIS_URL=redis://localhost:6383

# -- JWT Guard (consumer) ------------------------------------------------------
# Leave blank in dev → guard bypasses auth
AUTH_JWKS_URL=http://localhost:3002/.well-known/jwks.json

# -- Upstream services ---------------------------------------------------------
COMIC_SERVICE_URL=http://localhost:3001/api
STORAGE_SERVICE_URL=http://localhost:3003/api
SERVICE_TIMEOUT_MS=5000

# -- Internal ------------------------------------------------------------------
INTERNAL_API_SECRET=change-me-in-production

# -- Observability -------------------------------------------------------------
# Leave blank to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
