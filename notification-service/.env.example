PORT=3004
NODE_ENV=development
GLOBAL_PREFIX=api
CORS_ORIGINS=*

# PostgreSQL
DATABASE_URL=postgresql://postgres:secret@localhost:5435/notif_db

# Redis (for Bull queue)
REDIS_URL=redis://localhost:6382

# Auth Service JWKS
AUTH_JWKS_URL=http://localhost:3002/api/.well-known/jwks.json

# Kafka
KAFKA_BROKERS=localhost:9093
KAFKA_GROUP_ID=notification-service

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@comic-platform.com

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
