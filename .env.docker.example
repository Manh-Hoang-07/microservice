# Copy this file to ".env.docker" and adjust values, then run:
#   docker compose --env-file .env.docker up --build

# ─── RUNTIME ─────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_TIMEZONE=Asia/Ho_Chi_Minh
GLOBAL_PREFIX=api
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Use container hostname 'db' when running with docker compose
DATABASE_URL="postgresql://postgres:password@db:5432/comic_db"
DIRECT_URL="postgresql://postgres:password@db:5432/comic_db"

# ─── AUTH & SECURITY ──────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=auth-service
JWT_AUDIENCE=comic-platform

AUTH_JWKS_URL=http://auth-service:3002/.well-known/jwks.json
INTERNAL_API_SECRET=your-internal-api-secret-here

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
WEB_API_REDIS_URL=redis://web-api-redis:6379

# ─── KAFKA ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
EVENT_DRIVER=kafka
KAFKA_GROUP_ID=notification-service

# ─── GOOGLE OAUTH (auth-service) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/api/google/callback
GOOGLE_FRONTEND_URL=http://localhost:3000

# ─── MAIL (auth-service + notification-service) ───────────────────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# ─── STORAGE SERVICE ──────────────────────────────────────────────────────────
STORAGE_TYPE=s3
STORAGE_MAX_FILE_SIZE=10485760

STORAGE_S3_BUCKET=uploads
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_ENDPOINT=
STORAGE_S3_BASE_URL=
STORAGE_S3_FORCE_PATH_STYLE=true

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── WEB API SERVICE ──────────────────────────────────────────────────────────
COMIC_SERVICE_URL=http://comic-service:3001/api
POST_SERVICE_URL=http://post-service:3007/api
SERVICE_TIMEOUT_MS=5000
