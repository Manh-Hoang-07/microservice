# Copy to ".env.docker" and fill secrets, then run:
#   docker compose --env-file .env.docker up --build
#
# Contains ALL vars that docker-compose.yml interpolates.

# ─── SHARED ──────────────────────────────────────────────────────────────────
NODE_ENV=production
GLOBAL_PREFIX=api/v1
# Generate: openssl rand -base64 32
INTERNAL_API_SECRET=

# ─── KAFKA ───────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
EVENT_DRIVER=kafka

# ─── AUTH SERVICE ────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=auth-service
JWT_AUDIENCE=comic-platform
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/api/v1/auth/google/callback
GOOGLE_FRONTEND_URL=https://example.com

# ─── MAIL (auth + notification) ──────────────────────────────────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# ─── STORAGE SERVICE ─────────────────────────────────────────────────────────
STORAGE_TYPE=s3
STORAGE_MAX_FILE_SIZE=10485760
UPLOAD_DEST=./storage/uploads
STORAGE_S3_BUCKET=uploads
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_ENDPOINT=
STORAGE_S3_BASE_URL=
STORAGE_S3_FORCE_PATH_STYLE=true
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── WEB API SERVICE ─────────────────────────────────────────────────────────
AUTH_JWKS_URL=http://auth-service:3001/.well-known/jwks.json
COMIC_SERVICE_URL=http://comic-service:3009/api/v1
POST_SERVICE_URL=http://post-service:3008/api/v1
SERVICE_TIMEOUT_MS=5000

# ─── IAM SERVICE ─────────────────────────────────────────────────────────────
RBAC_CACHE_TTL=86400
