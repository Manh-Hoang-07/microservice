# ─── APPLICATION ──────────────────────────────────────────────────────────────
APP_NAME="NestJS Backend"
NODE_ENV=production
PORT=8000
APP_VERSION=1.0.0
APP_URL=http://localhost:8000
GLOBAL_PREFIX=api
APP_TIMEZONE=Asia/Ho_Chi_Minh
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000

# ─── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:123456@localhost:5432/comic"
DIRECT_URL="postgresql://postgres:123456@localhost:5432/comic"
DB_ID_TYPE=bigint
DB_CONNECTION_LIMIT=200

# ─── SECURITY & AUTH ──────────────────────────────────────────────────────────
ENCRYPTION_KEY=your-32-character-secret-key-here
JWT_SECRET="SECRET-BACKEND-V1"
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET="REFRESH-SECRET-BACKEND-V1"
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=nestjs-backend
JWT_AUDIENCE=nestjs-frontend

# ─── LOGGING & CACHE ──────────────────────────────────────────────────────────
# Log drivers: console, file, logtail (comma separated)
LOG_DRIVERS=console,file
LOG_DIR=./logs
LOGTAIL_TOKEN=

# Cache drivers: redis, memory
CACHE_DRIVER=redis
REDIS_URL=redis://localhost:6379

# ─── STORAGE ──────────────────────────────────────────────────────────────────
# storage type: s3, local
STORAGE_TYPE=s3
UPLOAD_DEST=./storage/uploads
MAX_FILE_SIZE=10485760

# S3 / Supabase Configuration
STORAGE_S3_BUCKET=uploads
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_ENDPOINT=
STORAGE_S3_FORCE_PATH_STYLE=true
STORAGE_S3_BASE_URL=

# ─── THIRD PARTY SERVICES ─────────────────────────────────────────────────────
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/api/google/callback
GOOGLE_FRONTEND_URL=http://localhost:3000

# VNPay
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=

# ─── OTHERS ───────────────────────────────────────────────────────────────────
THROTTLE_DISABLED=true