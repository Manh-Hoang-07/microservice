# Copy this file to ".env.docker" and fill ALL secret values, then run:
#   docker compose --env-file .env.docker up --build
#
# Required-secret values (POSTGRES_PASSWORD, INTERNAL_API_SECRET, JWT_*) MUST
# be replaced before docker compose will start. The compose file uses the
# `${VAR:?error}` fail-fast syntax to enforce this.

# ─── RUNTIME ─────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_TIMEZONE=Asia/Ho_Chi_Minh
GLOBAL_PREFIX=api
CORS_ENABLED=true
# In production CORS_ORIGINS MUST be a non-empty list, never "*".
CORS_ORIGINS=https://example.com

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Required: shared POSTGRES_PASSWORD (used by every service's DB). Generate:
#   openssl rand -base64 24
POSTGRES_PASSWORD=

# ─── AUTH & SECURITY ──────────────────────────────────────────────────────────
# RSA key pair (PEM). Generate locally:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
# Optional during a key rotation window — see PRODUCTION_READINESS_PLAN.md §1.6
JWT_PRIVATE_KEY_PEM_PREVIOUS=
JWT_PUBLIC_KEY_PEM_PREVIOUS=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=auth-service
JWT_AUDIENCE=comic-platform

AUTH_JWKS_URL=http://auth-service:3002/.well-known/jwks.json
# Required: shared secret for service-to-service auth (≥32 chars). Generate:
#   openssl rand -base64 32
INTERNAL_API_SECRET=

# OAuth state cookie HMAC key (auth-service). Generate:
#   openssl rand -base64 32
GOOGLE_OAUTH_STATE_SECRET=

# ─── KAFKA ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
EVENT_DRIVER=kafka
KAFKA_GROUP_ID=notification-service

# ─── GOOGLE OAUTH (auth-service) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/api/auth/google/callback
GOOGLE_FRONTEND_URL=https://example.com

# ─── MAIL (auth-service + notification-service) ───────────────────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# ─── STORAGE SERVICE ──────────────────────────────────────────────────────────
STORAGE_TYPE=s3
STORAGE_MAX_FILE_SIZE=10485760
STORAGE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif

STORAGE_S3_BUCKET=uploads
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_ENDPOINT=
STORAGE_S3_BASE_URL=
STORAGE_S3_FORCE_PATH_STYLE=true

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── WEB API SERVICE ──────────────────────────────────────────────────────────
COMIC_SERVICE_URL=http://comic-service:3001/api
POST_SERVICE_URL=http://post-service:3007/api
SERVICE_TIMEOUT_MS=5000
