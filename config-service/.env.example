PORT=3005
NODE_ENV=development
GLOBAL_PREFIX=api
CORS_ORIGINS=*

# PostgreSQL
DATABASE_URL=postgresql://postgres:secret@localhost:5436/config_db

# Auth (JWT Guard — leave empty for dev bypass)
AUTH_JWKS_URL=

# Internal API security
INTERNAL_API_SECRET=change-me-in-production

# OpenTelemetry (optional - set to enable tracing)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
