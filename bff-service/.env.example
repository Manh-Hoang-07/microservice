# ── App ────────────────────────────────────────────────────────────────────────
PORT=3006
NODE_ENV=development
GLOBAL_PREFIX=api
CORS_ORIGINS=*

# ── Auth (JWT Guard) ────────────────────────────────────────────────────────────
# Để trống khi dev local → guard tự bypass auth
AUTH_JWKS_URL=

# ── Upstream services ───────────────────────────────────────────────────────────
COMIC_SERVICE_URL=http://localhost:3001/api
MAIN_SERVICE_URL=http://localhost:8000/api
STORAGE_SERVICE_URL=http://localhost:3003/api

# Timeout (ms) khi gọi upstream
SERVICE_TIMEOUT_MS=5000

# ── Cache (Redis) ───────────────────────────────────────────────────────────────
# Để trống → caching bị disabled (BffCacheService tự skip)
BFF_REDIS_URL=

# OpenTelemetry (optional - set to enable tracing)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
