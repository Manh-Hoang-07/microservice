# syntax=docker/dockerfile:1.7
#
# Dev Dockerfile — hot-reload với nodemon, mount source code từ host.
#
# Required build args:
#   SERVICE_NAME — folder name under apps/ (e.g. "auth-service")
#   SERVICE_PORT — port the service listens on (e.g. "3001")

ARG NODE_VERSION=20-alpine

FROM node:${NODE_VERSION}
ARG SERVICE_NAME
ARG SERVICE_PORT=3000

ENV NODE_ENV=development \
    PORT=${SERVICE_PORT} \
    SERVICE_NAME=${SERVICE_NAME}

RUN apk add --no-cache dumb-init curl

WORKDIR /workspace

# Install dependencies (sẽ được cache nếu package*.json không đổi)
COPY package.json package-lock.json ./
COPY shared shared
COPY apps apps

RUN npm config set fetch-timeout 600000 && \
    npm config set fetch-retries 5 && \
    npm ci --ignore-scripts --no-audit --no-fund

# Build shared packages (cần cho import)
RUN npm run build:shared

# Prisma generate nếu có
RUN if [ -f apps/${SERVICE_NAME}/prisma/schema.prisma ]; then \
      npx --no -w apps/${SERVICE_NAME} prisma generate; \
    fi

EXPOSE ${SERVICE_PORT}

WORKDIR /workspace/apps/${SERVICE_NAME}

# Hot-reload với nodemon
CMD ["npx", "nodemon", "--watch", "src", "--watch", "../../shared", "--ext", "ts,json", "--exec", "ts-node -r tsconfig-paths/register src/main.ts"]
